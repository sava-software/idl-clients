# Whitelist .gitignore: ignore everything by default, explicitly re-include tracked content.

# Ignore everything
/*

# Re-include explicitly
!/.github/
!/.gitignore
!/.release-please-manifest.json
!/AGENTS.md
!/CHANGELOG.md
!/LICENSE
!/README.md
!/gradle/
!/gradle.properties
!/gradlew
!/gradlew.bat
!gradle/wrapper/gradle-wrapper.jar
!/idl-clients-*/
!/idls/
!/.junie/
!/main_net_programs.json
!/release-please-config.json
!/settings.gradle.kts

# Ignore build/IDE/temp output within re-included directories
.DS_Store
._*
*.log
hs_err_pid*.log
replay_pid*.log
**/build/
**/out/
**/target/
.gradle/
*.iml
.idea/
.vscode/
.project
.classpath
.settings/
**/generated/
*.swp
*.swo
*~
node_modules/
**/.cache/
Integ.*
*.bin
*.tar
*.tar.gz
*.tgz
